rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    
    function isShop() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "shop";
    }
    
    function isAdminOrShop() {
      return isAdmin() || isShop();
    }
    
    // Users collection
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
      allow read: if isShop();
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrShop();
    }
    
    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrShop();
    }
    
    // Brands collection
    match /brands/{brandId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrShop();
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || isAdminOrShop());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminOrShop();
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || isAdminOrShop());
    }
    
    // Collections
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrShop();
    }
    
    // Cart items
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Sales collection
    match /sales/{saleId} {
      allow read, create: if isAdminOrShop();
      allow update, delete: if isAdmin();
    }
    
    // Homepage settings
    match /homepage/{docId} {
      allow read: if true;
      allow write: if isAdminOrShop();
    }
    
    // Shop settings
    match /shop/{docId} {
      allow read: if true;
      allow write: if isAdminOrShop();
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
